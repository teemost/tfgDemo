# Trade Fast Gold — environment variables
# Copy this file to .env and fill in real values before running ./start.sh
# (or export them directly in your shell).

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Random secret used to sign session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=replace-with-a-long-random-string

# Optional
# LOG_LEVEL=info
# NODE_ENV=development
